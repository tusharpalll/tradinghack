// =============================================================================
// RSI Signals — Pane Indicator for TradingView
// =============================================================================
// Displays the RSI line in a separate pane below the price chart.
// Includes horizontal reference lines at 30/70/50, shaded overbought/oversold
// zones, and signal dots + labels at crossover/crossunder events.
//
// HOW TO USE:
//   1. Open TradingView and navigate to your chosen asset's chart.
//   2. Click "Pine Editor" at the bottom of the screen.
//   3. Paste this entire script into the editor.
//   4. Click "Add to chart" (or press Ctrl+Enter).
//   5. The RSI panel will appear below the price chart.
//
// STRATEGY:
//   RSI crosses below 30 (oversold)   → BUY  signal (green ● dot + ▲ label)
//   RSI crosses above 70 (overbought) → SELL signal (red   ● dot + ▼ label)
//
// Compatible with: BTCUSD, NSE:NIFTY, BSE:SENSEX, and any other symbol.
// =============================================================================

//@version=5
indicator(
    title            = "RSI Signals – Pane",
    shorttitle       = "RSI Pane",
    overlay          = false,          // RSI plots in its own separate pane
    max_labels_count = 500
)

// -----------------------------------------------------------------------------
// Inputs — editable from the indicator settings dialog in TradingView
// -----------------------------------------------------------------------------

rsiLength = input.int(
    defval  = 14,
    minval  = 2,
    maxval  = 200,
    title   = "RSI Length",
    tooltip = "Number of bars used to calculate RSI. Standard value is 14."
)

overboughtLevel = input.int(
    defval  = 70,
    minval  = 50,
    maxval  = 100,
    title   = "Overbought Level",
    tooltip = "RSI above this level triggers a SELL signal."
)

oversoldLevel = input.int(
    defval  = 30,
    minval  = 0,
    maxval  = 50,
    title   = "Oversold Level",
    tooltip = "RSI below this level triggers a BUY signal."
)

// -----------------------------------------------------------------------------
// RSI Calculation
// -----------------------------------------------------------------------------

// Built-in ta.rsi() uses Wilder's smoothing (same method as the Python script)
rsiValue = ta.rsi(close, rsiLength)

// -----------------------------------------------------------------------------
// Signal Detection
// -----------------------------------------------------------------------------

// BUY : RSI has just crossed BELOW the oversold threshold
isBuySignal  = ta.crossunder(rsiValue, oversoldLevel)

// SELL: RSI has just crossed ABOVE the overbought threshold
isSellSignal = ta.crossover(rsiValue, overboughtLevel)

// -----------------------------------------------------------------------------
// Reference Lines
// -----------------------------------------------------------------------------

hline(overboughtLevel, title = "Overbought", color = color.red,   linestyle = hline.style_dashed, linewidth = 1)
hline(oversoldLevel,   title = "Oversold",   color = color.green, linestyle = hline.style_dashed, linewidth = 1)
hline(50,              title = "Midline",    color = color.gray,  linestyle = hline.style_dotted, linewidth = 1)

// -----------------------------------------------------------------------------
// Shaded Zones
// -----------------------------------------------------------------------------

// Shade the overbought zone (RSI between overboughtLevel and 100) in light red
obBand  = plot(overboughtLevel, title = "OB Band",     display = display.none)
topBand = plot(100,             title = "Top Band",     display = display.none)
fill(obBand, topBand, color = color.new(color.red, 88), title = "Overbought Zone")

// Shade the oversold zone (RSI between 0 and oversoldLevel) in light green
osBand     = plot(oversoldLevel, title = "OS Band",     display = display.none)
bottomBand = plot(0,             title = "Bottom Band", display = display.none)
fill(osBand, bottomBand, color = color.new(color.green, 88), title = "Oversold Zone")

// -----------------------------------------------------------------------------
// RSI Line (dynamically colored)
// -----------------------------------------------------------------------------

// Color changes based on zone: green when oversold, red when overbought, orange otherwise
rsiLineColor = rsiValue < oversoldLevel   ? color.new(color.green,  0) :
               rsiValue > overboughtLevel ? color.new(color.red,    0) :
               color.new(color.orange, 0)

plot(
    rsiValue,
    title     = "RSI",
    color     = rsiLineColor,
    linewidth = 2
)

// -----------------------------------------------------------------------------
// Signal Dots on the RSI Pane
// -----------------------------------------------------------------------------

plotshape(
    isBuySignal,
    title    = "RSI Buy Dot",
    location = location.absolute,
    style    = shape.circle,
    color    = color.new(color.green, 0),
    size     = size.small
)

plotshape(
    isSellSignal,
    title    = "RSI Sell Dot",
    location = location.absolute,
    style    = shape.circle,
    color    = color.new(color.red, 0),
    size     = size.small
)

// -----------------------------------------------------------------------------
// Labels on the RSI Pane at Signal Bars
// -----------------------------------------------------------------------------

if isBuySignal
    label.new(
        x         = bar_index,
        y         = oversoldLevel,
        text      = "▲ BUY\nRSI: " + str.tostring(math.round(rsiValue, 2)),
        style     = label.style_label_up,
        color     = color.new(color.green, 10),
        textcolor = color.white,
        size      = size.small,
        tooltip   = "RSI crossed below " + str.tostring(oversoldLevel) +
                    " — potential oversold / buy opportunity.\nRSI = " +
                    str.tostring(math.round(rsiValue, 2))
    )

if isSellSignal
    label.new(
        x         = bar_index,
        y         = overboughtLevel,
        text      = "▼ SELL\nRSI: " + str.tostring(math.round(rsiValue, 2)),
        style     = label.style_label_down,
        color     = color.new(color.red, 10),
        textcolor = color.white,
        size      = size.small,
        tooltip   = "RSI crossed above " + str.tostring(overboughtLevel) +
                    " — potential overbought / sell opportunity.\nRSI = " +
                    str.tostring(math.round(rsiValue, 2))
    )

// -----------------------------------------------------------------------------
// Alert Conditions
// -----------------------------------------------------------------------------

alertcondition(
    isBuySignal,
    title   = "RSI Buy Signal",
    message = "BUY signal on {{ticker}} ({{interval}}): RSI crossed below oversold level. Current RSI = {{plot_0}}."
)

alertcondition(
    isSellSignal,
    title   = "RSI Sell Signal",
    message = "SELL signal on {{ticker}} ({{interval}}): RSI crossed above overbought level. Current RSI = {{plot_0}}."
)
